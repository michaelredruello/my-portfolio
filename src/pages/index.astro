---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="My Portfolio">
  <!-- Header -->
  <header class="border-b border-gray-800 bg-[#0d1117]">
    <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
      <a href="/" class="text-white font-bold text-lg tracking-tight">Alex Dev</a>
      <nav class="flex items-center gap-6 text-sm font-medium text-gray-400">
        <a href="/" class="text-white">Projects</a>
        <a href="https://github.com" target="_blank" class="hover:text-white transition-colors">GitHub</a>
        <a href="mailto:hello@alex.dev" class="hover:text-white transition-colors">Contact</a>
      </nav>
    </div>
  </header>

  <!-- Main -->
  <main class="mx-auto max-w-5xl px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">Projects</h1>
      <p class="mt-2 text-gray-400">A collection of things I've built and shipped.</p>
    </div>

    {projects.length === 0 ? (
      <div class="rounded-md border border-dashed border-gray-800 p-8 text-center text-gray-500">
        No projects found. Add some to <code class="text-blue-400">src/data/projects.ts</code>.
      </div>
    ) : (
      <div class="flex flex-col gap-4">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    )}
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-800 bg-[#0d1117] mt-20">
    <div class="mx-auto max-w-5xl px-6 py-8 text-sm text-gray-500">
      Built with Astro & Tailwind.
    </div>
  </footer>
</Layout>
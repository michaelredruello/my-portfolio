---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="My Portfolio">
  <!-- Header -->
  <header class="border-b border-gray-800 bg-[#0d1117]">
    <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
      <a href="/" class="text-white font-bold text-lg tracking-tight">Michael Redruello</a>
    </div>
  </header>

  <!-- Main -->
  <main class="mx-auto max-w-5xl px-6 py-12">
    
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">About me</h1>
      <p class="mt-2 text-gray-400">
        Hi! I'm Michael, a front end developer living in Turin, Italy. I like to code websites and applications using my interests in videogames and web development.<br />
        I'm currently looking for new opportunities to grow and learn, so if you think I could be a good fit for your team, don't hesitate to reach out!<br />
        Email: <a class="text-blue-400 hover:underline">redruellomichael@gmail.com</a>
         
      </p>
    </div>

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">Projects</h1>
      <p class="mt-2 text-gray-400">A collection of things I've built and shipped.</p>
    </div>

    <div class="flex flex-col gap-4">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-800 bg-[#0d1117] mt-20">
    <div class="mx-auto max-w-5xl px-6 py-8 text-sm text-gray-500 flex justify-between items-center">
      <div>Built with Astro & Tailwind.</div>
      <div class="flex space-x-4">
        <a href="https://www.linkedin.com/in/michaelredruello" target="_blank" class="text-gray-400 hover:text-white transition">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="https://github.com/michaelredruello" target="_blank" class="text-gray-400 hover:text-white transition">
          <i class="fab fa-github"></i>
        </a>
      </div>
  </footer>
</Layout>
